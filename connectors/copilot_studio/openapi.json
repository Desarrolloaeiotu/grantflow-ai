{
  "swagger": "2.0",
  "info": {
    "title": "GrantFlow AI API",
    "description": "API de inteligencia comercial para prospección estratégica de oportunidades de financiamiento — aeioTU",
    "version": "1.0.0"
  },
  "host": "localhost:8000",
  "basePath": "/api/v1",
  "schemes": ["http"],
  "consumes": ["application/json"],
  "produces": ["application/json"],
  "securityDefinitions": {
    "api_key": {
      "type": "apiKey",
      "name": "X-API-Key",
      "in": "header"
    }
  },
  "security": [{"api_key": []}],
  "paths": {
    "/opportunities": {
      "get": {
        "operationId": "ObtenerPipelineActivo",
        "summary": "Obtener oportunidades GO del pipeline",
        "description": "Retorna lista de oportunidades con filtros. Útil para: ¿Qué oportunidades GO tenemos? ¿Cuáles vencen esta semana?",
        "parameters": [
          {
            "name": "decision",
            "in": "query",
            "type": "string",
            "enum": ["go", "no_go", "pending"],
            "description": "Filtrar por decisión"
          },
          {
            "name": "window",
            "in": "query",
            "type": "string",
            "description": "Ventana de mercado"
          },
          {
            "name": "urgency",
            "in": "query",
            "type": "string",
            "enum": ["high", "medium", "low"],
            "description": "Urgencia"
          },
          {
            "name": "score_min",
            "in": "query",
            "type": "integer",
            "description": "Score mínimo (0-10)"
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de oportunidades",
            "schema": {
              "type": "object",
              "properties": {
                "items": {"type": "array"},
                "total": {"type": "integer"}
              }
            }
          }
        }
      }
    },
    "/funders": {
      "get": {
        "operationId": "BuscarFinanciador",
        "summary": "Buscar financiador",
        "description": "Busca un financiador por nombre. Útil para: ¿Tenemos historial con X?",
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "type": "string",
            "required": true,
            "description": "Nombre del financiador"
          }
        ],
        "responses": {
          "200": {
            "description": "Información del financiador",
            "schema": {"type": "object"}
          }
        }
      }
    },
    "/rag/query": {
      "post": {
        "operationId": "ObtenerLeccionesAprendidas",
        "summary": "Buscar lecciones aprendidas",
        "description": "Búsqueda semántica en documentos de lecciones aprendidas. Útil para: ¿Qué aprendimos de proyectos con X?",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "query": {"type": "string"},
                "top_k": {"type": "integer", "default": 5}
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Resultados de búsqueda",
            "schema": {"type": "object"}
          }
        }
      }
    },
    "/contacts/verify": {
      "post": {
        "operationId": "VerificarEmailCEO",
        "summary": "Verificar email de CEO",
        "description": "Verifica si un email es válido usando Apollo.io",
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "email": {"type": "string"},
                "name": {"type": "string"}
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Resultado de verificación",
            "schema": {"type": "object"}
          }
        }
      }
    },
    "/opportunities/{opportunity_id}/status": {
      "patch": {
        "operationId": "ActualizarEstadoOportunidad",
        "summary": "Actualizar estado de oportunidad",
        "description": "Cambia el estado de una oportunidad (detected, reviewed, in_crm, discarded)",
        "parameters": [
          {
            "name": "opportunity_id",
            "in": "path",
            "type": "string",
            "required": true
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "type": "object",
              "properties": {
                "status": {"type": "string"},
                "decision": {"type": "string"}
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Oportunidad actualizada",
            "schema": {"type": "object"}
          }
        }
      }
    }
  }
}
