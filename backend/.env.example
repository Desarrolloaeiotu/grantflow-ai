# GrantFlow AI Backend Environment Variables
# Copy this file to .env and fill in the values for your environment

# === Database ===
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/grantflow
SUPABASE_URL=https://[YOUR_REF].supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# === AI & LLM ===
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# === Analysis Service ===
# Model name for strategic organization analysis
ANALYSIS_MODEL=claude-sonnet-4-5

# Timeout in seconds for Claude API calls
ANALYSIS_TIMEOUT=30.0

# === Automation ===
N8N_BASE_URL=http://localhost:5678

# === Alerts & Notifications ===
RESEND_API_KEY=re_...
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# === Contacts & Enrichment (activate month 5) ===
APOLLO_API_KEY=

# === Premium Sources (evaluate month 6) ===
INSTRUMENTL_API_KEY=

# === Application ===
NEXT_PUBLIC_API_URL=http://localhost:8000
JWT_SECRET=dev_secret_change_in_production
ENVIRONMENT=development

# === Exchange Rate ===
# USD to COP conversion rate (update monthly)
USD_TO_COP_RATE=4050.0

# === Copilot Studio Integration (S4.5) ===
GRANTFLOW_API_KEY=
COPILOT_TENANT_ID=
COPILOT_CLIENT_ID=
COPILOT_CLIENT_SECRET=
