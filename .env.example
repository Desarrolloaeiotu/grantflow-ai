# ──────────────────────────────────────────────────────────────────────────────
# GrantFlow AI — Variables de entorno
# Copia este archivo como .env y completa los valores reales.
# NUNCA commitear el .env con valores reales.
# ──────────────────────────────────────────────────────────────────────────────

# Base de datos
DATABASE_URL=postgresql://postgres:PASSWORD@db.REF.supabase.co:5432/postgres
SUPABASE_URL=https://REF.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# IA
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...          # Gemini text-embedding-004

# Automatización n8n
N8N_BASE_URL=http://VPS_IP:5678

# Alertas
RESEND_API_KEY=re_...
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Contactos — activar en mes 5
APOLLO_API_KEY=

# Grants premium — evaluar en mes 6 (NO activar en dev)
INSTRUMENTL_API_KEY=

# App
NEXT_PUBLIC_API_URL=http://localhost:8000
JWT_SECRET=cambia_este_secreto_en_produccion
ENVIRONMENT=development         # development | production

# Tipo de cambio USD → COP (actualizar mensualmente)
USD_TO_COP_RATE=4050

# Copilot Studio / Power Platform (S4.5)
GRANTFLOW_API_KEY=
COPILOT_TENANT_ID=
COPILOT_CLIENT_ID=
COPILOT_CLIENT_SECRET=
SHAREPOINT_SITE_URL=https://aeiotu.sharepoint.com/sites/Alianzas/GrantFlow
SHAREPOINT_FOLDER_KNOWLEDGE=GrantFlow/Conocimiento

# Proxy configuration — Opcional para bypass de Google Search
# Formato: http://user:pass@proxy-server:port
# Si no está configurado, scrapers usan conexión directa (puede ser bloqueado)
PROXY_URL=http://proxy-server:8080
